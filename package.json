{
  "name": "hausy",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "mobile": "npm run start --workspace=@hausy/mobile",
    "web": "npm run dev --workspace=@hausy/web",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.6",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
